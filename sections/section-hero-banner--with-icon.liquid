{% liquid
  assign section_id = section.id
  assign title = section.settings.title
  assign title_tag = section.settings.title_tag
  assign subtitle = section.settings.subtitle
%}

<section id="section-{{ section_id }}" class="w-full px-4 py-8">
    <!-- Rounded Container for the whole banner -->
    <div class="relative w-full h-[60vh] md:h-[80vh] rounded-3xl overflow-hidden bg-cover bg-center" 
        style="background-image: url('https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=2000');">
      
      <!-- Gradient Overlay for Contrast -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
      
      <!-- Left-Bottom Aligned Caption Content -->
      <div class="absolute bottom-0 left-0 p-8 md:p-16 text-white max-w-5xl">
        <!-- Icon -->
        <div class="mb-4 text-sky-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        
        <!-- Heading -->
        <h1 class="section-title text-white mx-auto mb-2 text-40 lg:!mx-0 font-medium tracking-tight md:mb-3 xl:text-64 lg:px-0">
          {{ title }}
        </h1>
        
        <!-- Subheading -->
        <p class="text-lg md:text-xl text-gray-200 mb-6">
          {{- subtitle -}}
        </p>
        
        <!-- Call to Action -->
        <button class="bg-sky-600 hover:bg-sky-700 text-white px-6 py-3 rounded-full font-semibold">
          Get Started
        </button>
      </div>
    </div>
  </section>

{% schema %}
  {
    "name": "Hero Banner with Icon",
    "settings": [
      {
        "type": "header",
        "content": "Content Alignment"
      },
      {
        "type": "select",
        "id": "horizontal_alignment",
        "label": "Horizontal alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left"
      },
      {
        "type": "richtext",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "select",
        "id": "title_tag",
        "label": "Title Tag",
        "default": "h1",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          }
        ]
      },
      {
        "type": "number",
        "id": "title_max_width_mobile",
        "label": "Title Max Width Mobile"
      },
      {
        "type": "number",
        "id": "title_max_width_desktop",
        "label": "Title Max Width Desktop"
      },
      {
        "type": "richtext",
        "id": "subtitle",
        "label": "Subtitle"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "header",
        "content": "Paddings"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top Desktop (px)",
        "info": "From 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom Desktop (px)",
        "info": "From 768px",
        "default": 0
      }
    ],
    "presets": [
      {
        "name": "Hero Banner with Icon"
      }
    ]
  }
{% endschema %}
