<script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "LifeSync",
  "url": {{ request.origin | json }},
  "logo": {{ section.settings.footer_logo | image_url | prepend: 'https:' | json }},
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": {{ settings.store_phone_number | json }},
    "contactType": "customer service"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": {{ settings.store_address | json }}
  },
  "sameAs": [
    {% if settings.socials_x != blank %}{{ settings.socials_x | json }}{% endif %}{% if settings.socials_linkedin != blank %}{% if settings.socials_x != blank %},{% endif %}{{ settings.socials_linkedin | json }}{% endif %}
  ],
  "description": {{ section.settings.description | json }}
  }
</script>
