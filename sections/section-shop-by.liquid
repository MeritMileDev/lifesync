{% liquid
  assign section_id = section.id

  assign title = section.settings.title

  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop
%}

{% render 'offset',
  id: section_id,
  padding_top_mobile: padding_top_mobile,
  padding_bottom_mobile: padding_bottom_mobile,
  padding_top_desktop: padding_top_desktop,
  padding_bottom_desktop: padding_bottom_desktop
%}

<section id="section-{{ section_id }}">
  <div class="container">
    {% if title != blank %}
      <div class="mb-4 text-center text-32 font-medium xl:text-5xl xl:mb-12.5">{{ title }}</div>
    {% endif %}
    <div class="grid gap-6 lg:grid-cols-2">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          {% if block.settings['text_max-width'] > 0 %}
            <style>
              .card-text-{{ block.id }} {
                max-width: {{ block.settings.text_max-width }}px;
                margin-inline: auto;
                @media screen and (min-width: 768px) {
                  max-width: 100%;
                }
              }
            </style>
          {% endif %}
          {% liquid
            assign card_image_mobile = block.settings.card_image_mobile
            assign card_image_desktop = block.settings.card_image_desktop
            assign heading = block.settings.heading
            assign title = block.settings.title
            assign text = block.settings.text
            assign button_text = block.settings.button_text
            assign card_link = block.settings.card_link
          %}
          <div class="bg-bright-gray-20 p-6 text-center lg:flex lg:flex-col lg:pb-20 rounded-3xl">
            {% if card_image_mobile or card_image_desktop %}
              {% render 'picture',
                image_mobile: card_image_mobile,
                image_desktop: card_image_desktop,
                class: 'w-full mb-4 lg:mb-0'
              %}
            {% endif %}
            {% if heading != blank %}
              <div class="mb-2 text-sm font-medium uppercase tracking-wide text-police-blue-70 xl:mb-4.5">{{ heading }}</div>
            {% endif %}
            {% if title != blank %}
              <div class="mb-2 text-3xl font-bold xl:text-xl xl:mb-4.5">{{ title }}</div>
            {% endif %}
            {% if text != blank %}
              <div class="card-text-{{ block.id }} mb-8 max-w-72">{{ text }}</div>
            {% endif %}
            {% if button_text != blank and card_link != blank %}
              <a
                href="{{ card_link }}"
                class="flex items-center justify-center gap-2 bg-police-accent px-4 py-4 text-center text-sm font-medium  tracking-wide text-white transition duration-100 hover:scale-102 active:scale-100 disabled:opacity-20 lg:mt-auto lg:w-75 lg:mx-auto"
                style="border-radius: 24px;"
              >
                {{- button_text -}}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Shop By",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "header",
        "content": "Paddings"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top Desktop (px)",
        "info": "From 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom Desktop (px)",
        "info": "From 768px",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "card",
        "name": "Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "card_image_mobile",
            "label": "Card Image Mobile"
          },
          {
            "type": "image_picker",
            "id": "card_image_desktop",
            "label": "Card Image Desktop"
          },
          {
            "type": "url",
            "id": "card_link",
            "label": "Card Link"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "number",
            "id": "text_max-width",
            "label": "Text Max Width",
            "info": "Max width of the text in pixels for mobile. Leave blank for full width."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title"
          },
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          },
          {
            "type": "text",
            "id": "button_text",
            "label": "Button Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Shop By"
      }
    ]
  }
{% endschema %}
