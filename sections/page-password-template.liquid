<div class="container">
	<div class="lg:grid flex lg:grid-cols-12 grid-cols-2 lg:gap-6 gap-4 h-screen items-center">
		<div class="col-span-4 col-start-5 w-full">
			<div class="rounded-md bg-bright-gray lg:p-10 p-6">
				{% form 'storefront_password' %}
				{{ form.errors | default_errors }}
				<div class="relative lg:mb-6 mb-3">
					<input
						class="w-full px-5 pt-5 pb-2.5 border border-police-blue-70 placeholder:text-police-blue-70 hover:border-police-blue focus:!outline-police-blue focus:!outline focus:!outline-1 disabled:opacity-30 placeholder:opacity-0 peer"
						type="password" name="password" id="password" autofocus="" placeholder="password" />
					<label
						class="pl-5 absolute text-sm text-police-blue-70 duration-300 transform -translate-y-1.5 top-2 z-10 peer-placeholder-shown:text-base peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:top-1/2 peer-focus:top-2 peer-focus:text-sm peer-focus:-translate-y-1.5 start-0 cursor-text pointer-events-none">Password</label>
				</div>
				<input
					class="flex gap-2 items-center justify-center text-center font-medium text-police-blue px-10 py-4.25 text-sm uppercase bg-yellow hover:scale-102 active:scale-100 disabled:opacity-20 cursor-pointer w-full transition duration-100"
					name="commit" type="submit" value="Enter" />
				{% endform %}
			</div>
		</div>
	</div>
</div>

<style>
	.errors {
		margin-bottom: 12px;
		color: #D80004;
	}
</style>
