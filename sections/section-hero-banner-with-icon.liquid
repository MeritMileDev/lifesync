{% liquid
  assign section_id = section.id

  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop

  assign image_mobile = section.settings.image_mobile
  assign image_desktop = section.settings.image_desktop
  assign banner_icon = section.settings.banner_icon
  assign title = section.settings.title
  assign title_tag = section.settings.title_tag
  assign subtitle = section.settings.subtitle
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign title_max_width_mobile = section.settings.title_max_width_mobile
  assign title_max_width_desktop = section.settings.title_max_width_desktop

%}
{% if image_desktop and image_mobile %}
  <section id="section-{{ section_id }}" class="w-full px-4 py-4">
    <!-- Rounded Container for the whole banner -->
    <div class="image-wrapper relative w-full h-[60vh] rounded-3xl overflow-hidden bg-cover bg-center">
      
      <!-- Gradient Overlay for Contrast -->
      <div class="hidden absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
      
      <!-- Left-Bottom Aligned Caption Content -->
      <div class="absolute bottom-0 left-0 p-8 md:p-16 text-white max-w-5xl">
        <!-- Icon -->
        {% if banner_icon != blank %}
          {% render 'picture',
            image_mobile: banner_icon,
            image_desktop: banner_icon,
            is_full_size: false,
            class: 'lg:mb-8 mb-6'
          %}
        {% endif %}
        
        <!-- Heading -->
        <{{ title_tag }} class="section-title text-white mx-auto mb-2 text-32 md:text-40 font-medium md:mb-3 xl:text-64 {% unless title_max_width_mobile > 0 or title_max_width_desktop > 0 %} max-w-165 {% endunless %}">
          {{- title -}}
        </{{ title_tag }}>
        
        <!-- Subheading -->
        <div class="section-subtitle text-white {% if button_link != blank %}lg:mb-8 mb-6{% endif %} {% if section.settings.subtitle_full_width == false %} max-w-56{% endif %} md:max-w-max text-left lg:text-3xl md:text-lg text-md">
          {{- subtitle -}}
        </div>
        
        <!-- Call to Action -->
        {% if button_link != blank %}
          <a
            class="flex gap-2 items-center justify-center text-center font-medium text-police-blue px-10 py-4.25 text-sm uppercase bg-yellow hover:scale-102 active:scale-100 disabled:opacity-20 transition duration-100 lg:max-w-max {% if horizontal_alignment == 'center' %} lg:mx-auto {% elsif horizontal_alignment == 'right' %} lg:ml-auto {% endif %}"
            href="{{ button_link }}"
          >
            {{- button_label -}}
          </a>
        {% endif %}
      </div>
    </div>
  </section>
{% endif %}
{% schema %}
  {
    "name": "Hero Banner with Icon",
    "settings": [
      {
        "type": "header",
        "content": "Content Alignment"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Mobile Image"
      },
      {
        "type": "image_picker",
        "id": "image_desktop",
        "label": "Desktop Image"
      },
      {
        "type": "select",
        "id": "horizontal_alignment",
        "label": "Horizontal alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left"
      },
      {
        "type": "image_picker",
        "id": "banner_icon",
        "label": "Icon"
      },
      {
        "type": "richtext",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "select",
        "id": "title_tag",
        "label": "Title Tag",
        "default": "h1",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          }
        ]
      },
      {
        "type": "number",
        "id": "title_max_width_mobile",
        "label": "Title Max Width Mobile"
      },
      {
        "type": "number",
        "id": "title_max_width_desktop",
        "label": "Title Max Width Desktop"
      },
      {
        "type": "richtext",
        "id": "subtitle",
        "label": "Subtitle"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      },
      {
        "type": "header",
        "content": "Paddings"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top Desktop (px)",
        "info": "From 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom Desktop (px)",
        "info": "From 768px",
        "default": 0
      }
    ],
    "presets": [
      {
        "name": "Hero Banner with Icon"
      }
    ]
  }
{% endschema %}
