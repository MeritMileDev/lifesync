{% liquid
  assign section_id = section.id

  assign title = section.settings.title

  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop

%}

{% render 'offset',
  id: section_id,
  padding_top_mobile: padding_top_mobile,
  padding_bottom_mobile: padding_bottom_mobile,
  padding_top_desktop: padding_top_desktop,
  padding_bottom_desktop: padding_bottom_desktop
%}

<section id="section-{{ section_id }}">
  <div class="container">
    {% if title != blank %}
      <div class="mb-4 text-center text-32 font-medium xl:text-5xl xl:mb-12.5">{{ title }}</div>
    {% endif %}
    <div class="grid gap-6 lg:grid-cols-3">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          {% if block.settings['text_max-width'] > 0 %}
            <style>
              .card-text-{{ block.id }} {
                max-width: {{ block.settings.text_max-width }}px;
                margin-inline: auto;
                @media screen and (min-width: 768px) {
                  max-width: 100%;
                }
              }
            </style>
          {% endif %}
          {% liquid
            assign card_image_mobile = block.settings.card_image_mobile
            assign card_image_desktop = block.settings.card_image_desktop
            assign heading = block.settings.heading
            assign title = block.settings.title
            assign text = block.settings.text
            assign button_text = block.settings.button_text
            assign card_link = block.settings.card_link
          %}
          <div class="text-center lg:flex lg:flex-col">
            {% if card_image_mobile or card_image_desktop %}
              {% render 'picture',
                image_mobile: card_image_mobile,
                image_desktop: card_image_desktop,
                class: 'w-full mb-4 lg:mb-0'
              %}
            {% endif %}
            {% if title != blank %}
              <div class="text-left text-white px-5 text-3xl font-bold lg:mb-4 mb-2" style="margin-top: -50px;">{{ title }}</div>
            {% endif %}
            <div class="flex flex-col justify-between text-lg text-left px-5 py-5 bg-bright-gray-20 rounded-b-xl">
              {% if heading != blank %}
                <div class="text-left mb-2 text-lg font-bold tracking-wide text-police-blue mb-3">{{ heading }}</div>
                {% endif %}
              {% if text != blank %}
                <div class="card-text-{{ block.id }} text-police-blue max-w-md">{{ text }}</div>
              {% endif %}
              {% if button_text != blank and card_link != blank %}
                <a
                  href="{{ card_link }}"
                  class="flex items-start justify-center gap-2 px-4 text-left text-sm font-medium tracking-wide text-police-accent transition duration-100 hover:scale-102 active:scale-100 disabled:opacity-20"
                >
                  {{- button_text -}}
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M15.5855 9.39804L10.523 14.4605C10.4174 14.5661 10.2743 14.6254 10.125 14.6254C9.97573 14.6254 9.83258 14.5661 9.72703 14.4605C9.62148 14.355 9.56219 14.2118 9.56219 14.0626C9.56219 13.9133 9.62148 13.7701 9.72703 13.6646L13.8298 9.56257H2.8125C2.66332 9.56257 2.52024 9.50331 2.41475 9.39782C2.30926 9.29233 2.25 9.14925 2.25 9.00007C2.25 8.85088 2.30926 8.70781 2.41475 8.60232C2.52024 8.49683 2.66332 8.43757 2.8125 8.43757H13.8298L9.72703 4.33554C9.62148 4.22999 9.56219 4.08684 9.56219 3.93757C9.56219 3.7883 9.62148 3.64515 9.72703 3.5396C9.83258 3.43405 9.97573 3.37476 10.125 3.37476C10.2743 3.37476 10.4174 3.43405 10.523 3.5396L15.5855 8.6021C15.6378 8.65434 15.6793 8.71638 15.7076 8.78466C15.7359 8.85295 15.7504 8.92615 15.7504 9.00007C15.7504 9.07399 15.7359 9.14719 15.7076 9.21547C15.6793 9.28376 15.6378 9.3458 15.5855 9.39804Z" fill="#FFFFFF" stroke="#FFFFFF" stroke-width="0.5"/>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Innovations",
    "settings": [
      {
        "type": "richtext",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "header",
        "content": "Paddings"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top Desktop (px)",
        "info": "From 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom Desktop (px)",
        "info": "From 768px",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "card",
        "name": "Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "card_image_mobile",
            "label": "Card Image Mobile"
          },
          {
            "type": "image_picker",
            "id": "card_image_desktop",
            "label": "Card Image Desktop"
          },
          {
            "type": "url",
            "id": "card_link",
            "label": "Card Link"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "number",
            "id": "text_max-width",
            "label": "Text Max Width",
            "info": "Max width of the text in pixels for mobile. Leave blank for full width."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title"
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Text"
          },
          {
            "type": "text",
            "id": "button_text",
            "label": "Button Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Innovations"
      }
    ]
  }
{% endschema %}
