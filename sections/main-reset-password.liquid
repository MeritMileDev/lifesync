{% liquid
  assign section_id = section.id

  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop
%}

{% render 'offset',
  id: section_id,
  padding_top_mobile: padding_top_mobile,
  padding_bottom_mobile: padding_bottom_mobile,
  padding_top_desktop: padding_top_desktop,
  padding_bottom_desktop: padding_bottom_desktop
%}

<section id="section-{{ section_id }}">
  <div class="overflow-hidden">
    <div class="container">
      <div>
        <div class="!mt-10 mb-10 xl:col-span-5 max-w-165 mx-auto xl:!mt-0 xl:py-24 xl:pr-14">
          <h1 class="mb-8 text-center text-32 font-medium leading-10 xl:mb-19.5 xl:text-5xl">
            {{ 'customer.reset_password.title' | t }}
          </h1>
          {%- form 'reset_customer_password' -%}
            {%- if form.errors -%}
              <h2 class="form__message" tabindex="-1" autofocus>
                <span class="visually-hidden">{{ 'accessibility.error' | t }} </span>
                {{ 'templates.contact.form.error_heading' | t }}
              </h2>
              <ul class="text-red">
                {%- for field in form.errors -%}
                  <li>
                    {%- if field == 'form' -%}
                      {{ form.errors.messages[field] }}
                    {%- else -%}
                      <a href="#{{ field }}">
                        {{ form.errors.translated_fields[field] | capitalize }}
                        {{ form.errors.messages[field] }}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="field mt-6">
              <div class="relative">
                <input
                  class="peer w-full border border-police-blue-70 px-5 pb-2.5 pt-5 placeholder:text-police-blue-70 placeholder:opacity-0 hover:border-police-blue focus:!outline focus:!outline-police-blue focus:!outline-1 disabled:opacity-30"
                  type="password"
                  name="customer[password]"
                  id="password"
                  autocomplete="new-password"
                  {% if form.errors contains 'password' %}
                    aria-invalid="true"
                    aria-describedby="password-error"
                  {% endif %}
                  placeholder="{{ 'customer.reset_password.password' | t }}"
                >
                <label class="absolute start-0 top-2 z-10 -translate-y-1.5 transform cursor-text pl-5 text-sm text-police-blue-70 duration-300 peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base peer-focus:top-2 peer-focus:-translate-y-1.5 peer-focus:text-sm" for="password">
                  {{ 'customer.reset_password.password' | t }}
                </label>
              </div>
              {%- if form.errors contains 'password' -%}
                <small id="password-error" class="form__message text-red">
                  {{ form.errors.translated_fields.password | capitalize }}
                  {{ form.errors.messages.password }}
                </small>
              {%- endif -%}
            </div>

            <div class="field mt-6">
              <div class="relative">
                <input
                  class="peer w-full border border-police-blue-70 px-5 pb-2.5 pt-5 placeholder:text-police-blue-70 placeholder:opacity-0 hover:border-police-blue focus:!outline focus:!outline-police-blue focus:!outline-1 disabled:opacity-30"
                  type="password"
                  name="customer[password_confirmation]"
                  id="password_confirmation"
                  autocomplete="new-password"
                  {% if form.errors contains 'password_confirmation' %}
                    aria-invalid="true"
                    aria-describedby="password_confirmation-error"
                  {% endif %}
                  placeholder="{{ 'customer.reset_password.password_confirm' | t }}"
                >
                <label class="absolute start-0 top-2 z-10 -translate-y-1.5 transform cursor-text pl-5 text-sm text-police-blue-70 duration-300 peer-placeholder-shown:top-1/2 peer-placeholder-shown:-translate-y-1/2 peer-placeholder-shown:text-base peer-focus:top-2 peer-focus:-translate-y-1.5 peer-focus:text-sm" for="password_confirmation">
                  {{ 'customer.reset_password.password_confirm' | t }}
                </label>
              </div>
              {%- if form.errors contains 'password_confirmation' -%}
                <small id="password_confirmation-error" class="form__message">
                  <svg aria-hidden="true" focusable="false">
                    <use href="#icon-error" />
                  </svg>
                  {{ form.errors.translated_fields.password_confirmation | capitalize }}
                  {{ form.errors.messages.password_confirmation }}
                </small>
              {%- endif -%}
            </div>

            <button class="flex w-full mt-6 gap-2 items-center justify-center text-center text-police-blue px-10 py-4.25 text-sm uppercase bg-yellow hover:scale-102 active:scale-100 disabled:opacity-20 transition duration-100">
              <span>
                {{ 'customer.reset_password.submit' | t }}
              </span>
            </button>
          {% endform %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reset Password",
  "settings": []
}
{% endschema %}
