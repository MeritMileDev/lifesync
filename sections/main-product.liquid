<section class="product-main">
  <div
    id="MainProduct-{{ section.id }}"
    data-section="{{ section.id }}"
  >
    <div class="container">
      {% liquid
        if product.selected_variant.id
          assign selected_variant_id = product.selected_variant.id
        else
          assign selected_variant_id = 'null'
        endif
      %}
      <div
        class="product"
        x-data="variants('{{ product.id }}', {{ product.selected_or_first_available_variant.options.size }}, '{{ product.url }}', {{ selected_variant_id }})"
      >
        <div class="items-start xl:grid xl:grid-cols-12 xl:gap-6">
          <div class="product-media relative xl:col-span-7">
            {% render 'product-gallery', product %}
          </div>

          <div class="product-info xl:sticky xl:top-15 xl:col-span-5 xl:row-span-5 2xl:pl-17.5">
            {% render 'product-info', product, section_blocks: section.blocks %}
          </div>

          <div class="xl:col-span-7">
            {% render 'product-tabs', product: product %}
          </div>
          <div class="xl:col-span-7">
            {% for block in section.blocks %}
              {% if block.type == 'product_slider' %}
                {% render 'rebuy-slider-widget', settings: block.settings, id: block.id %}
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json">
      {
        "@context": "http://schema.org/",
        "@type": "Product",
        "name": {{ product.title | json }},
                "url": {{ request.origin | append: product.url | json }},
                "image": [
      {{ product.images.first | image_url: width: 1920 | prepend: "https:" | json }}
      ],
      "description": {{ product.description | strip_html | json }},
    {% if product.selected_or_first_available_variant.sku != blank -%}
                  "sku": {{ product.selected_or_first_available_variant.sku | json }},
                {%- endif %}
                {% if product.metafields.yotpo.reviews_count and product.metafields.yotpo.reviews_count != '0' -%}
                  "aggregateRating": {
                    "@type": "AggregateRating",
                    "ratingValue": "{{ product.metafields.yotpo.reviews_average }}",
                    "reviewCount": "{{ product.metafields.yotpo.reviews_count }}"
                  },
                {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
      {%- for variant in product.variants -%}
                    {
                      "@type" : "Offer",
                      {%- if variant.sku != blank -%}
                        "sku": {{ variant.sku | json }},
                      {%- endif -%}
        {%- if variant.barcode.size == 12 -%}
                        "gtin12": {{ variant.barcode | json }},
                      {%- endif -%}
        {%- if variant.barcode.size == 13 -%}
                        "gtin13": {{ variant.barcode | json }},
                      {%- endif -%}
        {%- if variant.barcode.size == 14 -%}
                        "gtin14": {{ variant.barcode | json }},
                      {%- endif -%}
                      "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
                      "price" : {{ variant.price | divided_by: 100.00 | json }},
                      "priceCurrency" : {{ cart.currency.iso_code | json }},
                      "url" : {{ request.origin | append: variant.url | json }}
                    }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
      ]
    }
  </script>
  <div
    x-cloak
    @set-product-error.window="errorMessage = $event.detail"
    x-show="errorMessage"
    x-data="{errorMessage: null}"
    class="fixed inset-0 z-50 flex items-center bg-black/40 px-2.5 py-5"
  >
    <div class="mx-auto max-w-165 bg-white" @click.outside="errorMessage = null">
      <div class="border-b border-gray-100 p-5 pb-10 text-xl" x-text="errorMessage"> </div>
      <div class="p-5">
        <button
          @click="errorMessage = null"
          class="flex w-full items-center justify-center gap-2 border border-police-blue bg-white px-10 py-1.25 text-center text-sm font-medium uppercase tracking-wide text-police-blue transition duration-100 hover:scale-102 active:scale-100 disabled:opacity-30"
          >Okay</button
        >
      </div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Main product",
    "tag": "section",
    "class": "section",
    "blocks": [
      {
        "type": "@app"
      },
      {
        "type": "product_slider",
        "name": "Product Slider",
        "settings": [
          {
            "type": "text",
            "id": "id",
            "label": "Widget ID"
          },
          {
            "type": "checkbox",
            "id": "lazy_images",
            "label": "Lazy Load Images",
            "default": true
          },
          {
            "type": "number",
            "id": "slides_qty_for_desktop",
            "label": "Slides Qty for desktop",
            "default": 4
          },
          {
            "type": "header",
            "content": "Paddings"
          },
          {
            "type": "number",
            "id": "padding_top_mobile",
            "label": "Padding Top Mobile (px)",
            "info": "Until 768px",
            "default": 0
          },
          {
            "type": "number",
            "id": "padding_bottom_mobile",
            "label": "Padding Bottom Mobile (px)",
            "info": "Until 768px",
            "default": 0
          },
          {
            "type": "number",
            "id": "padding_top_desktop",
            "label": "Padding Top Desktop (px)",
            "info": "From 768px",
            "default": 0
          },
          {
            "type": "number",
            "id": "padding_bottom_desktop",
            "label": "Padding Bottom Desktop (px)",
            "info": "From 768px",
            "default": 0
          }
        ]
      }
    ],
    "settings": [
      {
        "type": "header",
        "content": "Contact Us Settings"
      },
      {
        "type": "image_picker",
        "id": "icon",
        "label": "Icon"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "richtext",
        "id": "subtitle",
        "label": "Subtitle"
      },
      {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
      },
      {
        "type": "header",
        "content": "Terms & Conditions Settings"
      },
      {
        "id": "link_url",
        "type": "url",
        "label": "Link URL"
      },
      {
        "id": "terms_link_text",
        "type": "text",
        "label": "Link Text",
        "default": "Terms and Conditions"
      },
      {
        "id": "terms_label_text",
        "type": "text",
        "label": "Label Text",
        "default": "By purchasing this product, you accept our"
      }
    ]
  }
{% endschema %}
