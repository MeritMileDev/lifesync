{% liquid
  assign section_id = section.id

  assign background_color_mobile = section.settings.background_color_mobile
  assign background_color_desktop = section.settings.background_color_desktop
  assign heading = section.settings.heading
  assign title = section.settings.title
  assign image_mobile = section.settings.image_mobile
  assign image_desktop = section.settings.image_desktop

  assign padding_top_mobile = section.settings.padding_top_mobile
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile
  assign padding_top_desktop = section.settings.padding_top_desktop
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop
%}

{% render 'offset',
  id: section_id,
  padding_top_mobile: padding_top_mobile,
  padding_bottom_mobile: padding_bottom_mobile,
  padding_top_desktop: padding_top_desktop,
  padding_bottom_desktop: padding_bottom_desktop
%}

<section id="section-{{ section_id }}">
  <div class="container">
    <div class="text-left lg:grid lg:grid-cols-2 lg:gap-20">
      <div class="py-4 lg:py-0"></div>
      <div class="lg:col-start-2 row-start-1 lg:flex lg:flex-col lg:justify-center lg:items-start lg:border-t lg:border-b lg:border-police-blue-20 px-10">
        <div class="mb-2 text-sm font-medium uppercase tracking-wide text-police-blue-70 xl:mb-4.5">{{ heading }}</div>
        <div class="mb-7 text-32 font-medium xl:mb-4.5 xl:tracking-tight xl:max-w-80 2xl:text-48 2xl:max-w-120">{{ title }}</div>
      </div>
      <div class="lg:col-start-1 row-start-1">
        {% render 'picture', image_mobile: image_mobile, image_desktop: image_desktop, class: 'w-full rounded-xl' %}
      </div>
    </div>
  </div>
</section>

{% style %}
  #section-{{ section_id }} {
    background-color:  {{ background_color_mobile }};
  }

  @media screen and (min-width: 768px) {
    #section-{{ section_id }} {
      background-color: {{ background_color_desktop }};
    }
  }
{% endstyle %}

{% schema %}
  {
    "name": "Image with text secondary",
    "settings": [
      {
        "type": "color",
        "id": "background_color_mobile",
        "label": "Background Color Mobile",
        "default": "transparent"
      },
      {
        "type": "color",
        "id": "background_color_desktop",
        "label": "Background Color Desktop",
        "default": "transparent"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "Image Mobile"
      },
      {
        "type": "image_picker",
        "id": "image_desktop",
        "label": "Image Desktop"
      },
      {
        "type": "header",
        "content": "Paddings"
      },
      {
        "type": "number",
        "id": "padding_top_mobile",
        "label": "Padding Top Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_mobile",
        "label": "Padding Bottom Mobile (px)",
        "info": "Until 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_top_desktop",
        "label": "Padding Top Desktop (px)",
        "info": "From 768px",
        "default": 0
      },
      {
        "type": "number",
        "id": "padding_bottom_desktop",
        "label": "Padding Bottom Desktop (px)",
        "info": "From 768px",
        "default": 0
      }
    ],
    "blocks": [
      {
        "type": "card",
        "name": "Card",
        "settings": [
          {
            "type": "image_picker",
            "id": "card_image_mobile",
            "label": "Card Image Mobile"
          },
          {
            "type": "image_picker",
            "id": "card_image_desktop",
            "label": "Card Image Desktop"
          },
          {
            "type": "url",
            "id": "card_link",
            "label": "Card Link"
          },
          {
            "type": "text",
            "id": "heading",
            "label": "Heading"
          },
          {
            "type": "number",
            "id": "text_max-width",
            "label": "Text Max Width",
            "info": "Max width of the text in pixels for mobile. Leave blank for full width."
          },
          {
            "type": "text",
            "id": "title",
            "label": "Title"
          },
          {
            "type": "text",
            "id": "text",
            "label": "Text"
          },
          {
            "type": "text",
            "id": "button_text",
            "label": "Button Text"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Image with text secondary"
      }
    ]
  }
{% endschema %}
